{
  "name": "parcel-react-tailwindcss-template",
  "version": "1.0.0",
  "description": "Minimal CodeSandbox template to use configurable Tailwind CSS with React v17",
  "scripts": {
    "clean": "rm -rf dist .cache",
    "build": "parcel build ./public/index.html --public-url /",
    "start": "parcel ./public/index.html"
  },
  "dependencies": {
    "@reach/router": "^1.3.4",
    "@types/jest": "^29.5.4",
    "@types/node": "^20.6.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-headroom": "^3.2.1",
    "react-instagram-authless-feed": "jamesmoriarty/react-instagram-authless-feed#v2.0.1",
    "react-router-dom": "^6.16.0",
    "react-router-scroll-top": "^0.3.1",
    "react-scroll-top": "^1.0.4",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@babel/core": "^7.22.19",
    "@babel/preset-react": "^7.22.15",
    "cssnano": "^6.0.1",
    "parcel-bundler": "^1.12.4"
  },
  "keywords": [
    "react",
    "parcel",
    "tailwind",
    "tailwind css",
    "tailwindcss"
  ]
}
